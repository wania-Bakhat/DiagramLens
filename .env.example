# Copy this file to .env.local, then add a newly generated key from Groq Console.
# Never put this value in a NEXT_PUBLIC_ variable or commit .env.local.
GROQ_API_KEY=
# Optional: change the model without editing code.
GROQ_MODEL=llama-3.3-70b-versatile
# The visual recognizer uses this vision-capable Groq model when OPENAI_API_KEY
# is not present. Keep API keys server-side; never use NEXT_PUBLIC_ for them.
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Optional preferred provider for the image recognizer. It defaults to GPT-5.6
# when present, making the submitted demo use the OpenAI vision workflow.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.6
